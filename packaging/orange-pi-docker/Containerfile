FROM fedora:42

RUN dnf install -y \
    ca-certificates \
    clang \
    curl \
    findutils \
    gcc \
    gcc-c++ \
    git \
    make \
    libdrm \
    libwayland-client \
    libwayland-server \
    libX11 \
    vulkan-loader \
    nodejs \
    npm \
    openssl-devel \
    pkg-config \
    python3.13 \
    python3.13-devel \
    rustup \
    tar \
    which \
 && dnf clean all

RUN useradd -m -u 1000 exo

USER exo
WORKDIR /home/exo

ENV HOME=/home/exo \
    CARGO_HOME=/home/exo/.cargo \
    RUSTUP_HOME=/home/exo/.rustup \
    PATH=/home/exo/.local/bin:/home/exo/.cargo/bin:${PATH} \
    XDG_CONFIG_HOME=/home/exo/.config \
    XDG_CACHE_HOME=/home/exo/.cache \
    XDG_DATA_HOME=/home/exo/.local/share

RUN rustup-init -y --default-toolchain nightly --profile minimal
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

ARG EXO_REPO=https://github.com/rcarmo/exo.git
ARG EXO_REF=orange/linux-vulkan-amd-tinygrad
RUN git clone --depth 1 --branch ${EXO_REF} ${EXO_REPO} /home/exo/exo

WORKDIR /home/exo/exo/dashboard
RUN npm install && npm run build

WORKDIR /home/exo/exo
RUN uv sync --extra cpu
RUN uv pip install --python /home/exo/exo/.venv/bin/python mlx-lm==0.31.1

EXPOSE 52415

CMD ["bash", "-lc", "uv run exo"]
